rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isProfileOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasAllowedProfileKeys() {
      return request.resource.data.keys().hasOnly([
        'businessType',
        'roles',
        'hours',
        'busyLevel',
        'peakStaff',
        'csvDemand',
        'dayConfigs',
        'operatingRules',
        'staffingFeedback',
        'ownerUid',
        'updatedAt'
      ]);
    }

    function changesAllowedProfileKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'businessType',
        'roles',
        'hours',
        'busyLevel',
        'peakStaff',
        'csvDemand',
        'dayConfigs',
        'operatingRules',
        'staffingFeedback',
        'ownerUid',
        'updatedAt'
      ]);
    }

    match /businessProfiles/{userId} {
      allow read: if isProfileOwner(userId);
      allow create: if isProfileOwner(userId)
        && request.resource.data.ownerUid == request.auth.uid
        && hasAllowedProfileKeys();
      allow update: if isProfileOwner(userId)
        && (!('ownerUid' in resource.data) || resource.data.ownerUid == request.auth.uid)
        && request.resource.data.ownerUid == request.auth.uid
        && changesAllowedProfileKeysOnly();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
